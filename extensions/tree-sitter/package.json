  "description": "TreeSitter grammar for the Orison programming language.",
  "main": "bindings/node",
  "keywords": [
    "parser",
    "tree-sitter",
    "orison"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
