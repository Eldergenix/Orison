{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orison.dev/schemas/registry-list.schema.json",
  "title": "Orison Registry Listing v1",
  "type": "object",
  "required": [
    "schema",
    "registry",
    "packages"
  ],
  "properties": {
    "schema": {
      "const": "ori.registry_list.v1"
    },
    "registry": {
      "type": "string",
      "minLength": 1
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "version",
          "bytes",
          "checksum",
          "yanked"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "checksum": {
            "type": "string",
            "pattern": "^[0-9a-f]+$"
          },
          "yanked": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema": "ori.registry_list.v1",
      "registry": "/var/registries/orison",
      "packages": [
        {
          "name": "app.users",
          "version": "0.1.0",
          "bytes": 4096,
          "checksum": "deadbeefcafebabe",
          "yanked": false
        },
        {
          "name": "app.users",
          "version": "0.1.1",
          "bytes": 4112,
          "checksum": "0123456789abcdef",
          "yanked": true
        }
      ]
    }
  ]
}
