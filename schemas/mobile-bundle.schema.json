{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ori.mobile_bundle.v1",
  "title": "Orison Mobile Bundle Report v1",
  "type": "object",
  "required": [
    "schema",
    "platform",
    "staging_dir",
    "files_written",
    "bytes_total",
    "validation"
  ],
  "properties": {
    "schema": {
      "const": "ori.mobile_bundle.v1"
    },
    "platform": {
      "enum": [
        "ios",
        "android"
      ]
    },
    "staging_dir": {
      "type": "string",
      "minLength": 1
    },
    "files_written": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "bytes_total": {
      "type": "integer",
      "minimum": 0
    },
    "validation": {
      "type": "object",
      "required": [
        "plist_valid",
        "manifest_valid",
        "required_assets_present"
      ],
      "properties": {
        "plist_valid": {
          "type": "boolean"
        },
        "manifest_valid": {
          "type": "boolean"
        },
        "required_assets_present": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
