{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orison.invalid/schemas/preprocess.schema.json",
  "title": "Orison Preprocess Report v1",
  "type": "object",
  "required": [
    "schema",
    "expanded",
    "diagnostics",
    "text"
  ],
  "properties": {
    "schema": {
      "const": "ori.preprocess.v1"
    },
    "expanded": {
      "type": "boolean",
      "description": "True if the preprocessor produced a text output (no fatal I/O errors). Diagnostics may still be present even when true."
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "diagnostic.schema.json"
      }
    },
    "text": {
      "type": "string",
      "description": "The expanded source text. Empty string when a fatal read error prevented preprocessing."
    },
    "path": {
      "type": "string",
      "description": "Source path that was preprocessed."
    }
  },
  "additionalProperties": false
}
