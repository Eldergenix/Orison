{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orison.dev/schemas/publish-receipt.schema.json",
  "title": "Orison Publish Receipt v1",
  "type": "object",
  "required": [
    "schema",
    "name",
    "version",
    "bytes",
    "checksum",
    "published_at_unix_seconds"
  ],
  "properties": {
    "schema": {
      "const": "ori.publish_receipt.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "bytes": {
      "type": "integer",
      "minimum": 1
    },
    "checksum": {
      "type": "string",
      "pattern": "^[0-9a-f]+$",
      "minLength": 16,
      "maxLength": 16
    },
    "published_at_unix_seconds": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema": "ori.publish_receipt.v1",
      "name": "app.users",
      "version": "0.2.1",
      "bytes": 4096,
      "checksum": "deadbeefcafebabe",
      "published_at_unix_seconds": 1747356800
    }
  ]
}
